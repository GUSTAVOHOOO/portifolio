---
import logoUrl from '../assets/logo/gmstudio-logo.svg?url'

const currentYear = new Date().getFullYear()
const whatsappPhone = '5543996142514'
const whatsappMessage = encodeURIComponent('Olá, vim pelo site da GMStudio')
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${whatsappMessage}`

const navLinks = [
  { href: '#servicos', label: 'Serviços' },
  { href: '#portfolio', label: 'Portfólio' },
  { href: '#sobre', label: 'Sobre' },
  { href: '#contato', label: 'Contato' },
]
---

<footer style="border-top: 1px solid var(--color-border); padding: var(--space-16) var(--space-6) var(--space-8);">
  <div style="max-width: 80rem; margin: 0 auto;">

    <div class="footer-grid">
      <!-- Brand column -->
      <div>
        <a href="/" style="text-decoration: none; display: inline-flex; align-items: center; gap: var(--space-2);">
          <img src={logoUrl} alt="GMStudio" width="32" height="32" loading="lazy" onerror="this.style.display='none'" />
          <span style="font-family: var(--font-heading); font-weight: 700; font-size: var(--text-lg); color: var(--color-text);">
            GMStudio
          </span>
        </a>
        <p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-3); max-width: 260px; line-height: var(--leading-normal);">
          Presença digital que converte — lojas online, landing pages e sites institucionais para empreendedores.
        </p>
      </div>

      <!-- Navigation column -->
      <div>
        <p style="font-family: var(--font-heading); font-weight: 700; font-size: var(--text-sm); color: var(--color-text); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin: 0 0 var(--space-4);">
          Navegação
        </p>
        <nav>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-2);">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-muted); text-decoration: none; transition: color var(--transition-base);"
                  class="footer-link"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Contact column -->
      <div>
        <p style="font-family: var(--font-heading); font-weight: 700; font-size: var(--text-sm); color: var(--color-text); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin: 0 0 var(--space-4);">
          Contato
        </p>
        <div style="display: flex; flex-direction: column; gap: var(--space-3);">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: var(--space-2);"
            class="footer-link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a
            href="mailto:contato@gmstudio.com.br"
            style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-muted); text-decoration: none;"
            class="footer-link"
          >
            contato@gmstudio.com.br
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid var(--color-border); margin-top: var(--space-12); padding-top: var(--space-6); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-4);">
      <p style="font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
        © {currentYear} GMStudio. Todos os direitos reservados.
      </p>
      <div style="display: flex; gap: var(--space-4); align-items: center;">
        <a
          href="https://instagram.com/gmstudio"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram da GMStudio"
          class="footer-link"
          style="color: var(--color-text-muted); display: inline-flex;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a
          href="https://linkedin.com/company/gmstudio"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn da GMStudio"
          class="footer-link"
          style="color: var(--color-text-muted); display: inline-flex;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--space-12);
    }
  }
  .footer-link:hover {
    color: var(--color-text) !important;
  }
</style>
