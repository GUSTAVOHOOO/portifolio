---
import { getCollection } from 'astro:content';
const projects = (await getCollection('projects'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
---

<section id="portfolio" class="section-animate" style="padding: var(--space-24) var(--space-4);">
  <div style="max-width: 80rem; margin: 0 auto;">
    <h2 style="font-family: var(--font-heading); font-size: var(--text-3xl); font-weight: 700; line-height: var(--leading-snug); letter-spacing: var(--tracking-tight); text-align: center; margin-bottom: var(--space-12); color: var(--color-text);">
      Nossos projetos
    </h2>

    {projects.length === 0 ? (
      <p class="text-center" style="color: var(--color-text-muted); font-family: var(--font-body);">
        Em breve novos projetos aqui.
      </p>
    ) : (
      <div class="portfolio-grid">
        {projects.map((project) => (
          <a
            href={project.data.liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Visitar ${project.data.title} (abre em nova aba)`}
            class="project-card glass-card stagger-child"
            style="display: block; text-decoration: none; overflow: hidden;"
          >
            <div style="width: 100%; aspect-ratio: 16/9; border-radius: var(--radius-lg) var(--radius-lg) 0 0; overflow: hidden; background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-accent-surface) 100%);">
              <img
                src={project.data.thumbnail}
                alt={project.data.title}
                loading="lazy"
                decoding="async"
                style="width: 100%; height: 100%; object-fit: cover; display: block;"
                onerror="this.style.display='none'"
              />
            </div>
            <div style="padding: var(--space-4);">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: var(--space-2);">
                <h3 style="font-family: var(--font-heading); font-size: var(--text-lg); font-weight: 700; color: var(--color-text); margin: 0;">
                  {project.data.title}
                </h3>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="color: var(--color-text-muted); flex-shrink: 0;">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </div>
              <span style="display: inline-block; margin-top: var(--space-2); background: var(--color-accent-surface); color: var(--color-accent); border-radius: var(--radius-full); padding: var(--space-1) var(--space-3); font-family: var(--font-body); font-size: var(--text-sm); font-weight: 400; text-transform: uppercase; letter-spacing: var(--tracking-wide);">
                {project.data.category}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .portfolio-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .portfolio-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 639px) {
    section {
      padding: var(--space-16) var(--space-4) !important;
    }
  }
  .project-card {
    border-radius: var(--radius-lg);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .project-card:hover {
    transform: translateY(-4px);
  }
</style>
