---
import { getCollection } from 'astro:content';
import StatsCounter from './StatsCounter.tsx';

const team = await getCollection('team');

const statsData = [
  { numericValue: 20, suffix: '+', label: 'Projetos' },
  { numericValue: 15, suffix: '+', label: 'Clientes' },
  { numericValue: 2,  suffix: '+', label: 'Anos' },
];

const values = [
  { name: 'Transparência', description: 'Sem surpresas, sem enrolação. Você sabe exatamente o que está sendo feito e quando — do briefing à entrega.' },
  { name: 'Qualidade', description: 'Cada pixel importa. Fazemos menos para fazer muito melhor, e o resultado aparece no design e na performance.' },
  { name: 'Resultado', description: 'Bonito não é suficiente. O site precisa ser rápido, aparecer no Google e trazer clientes de verdade.' },
  { name: 'Parceria', description: 'Você fala direto com quem cria. Sem intermediários, sem call center — somos o parceiro que você chama quando quer crescer.' },
];
---

<section id="sobre" class="section-with-eyebrow">
  <div style="max-width: 80rem; margin: 0 auto;">
    <span class="eyebrow-label">Quem somos</span>
    <h2 class="section-heading">Criatividade <em class="accent-italic">com propósito</em></h2>

    <!-- Agency story + stats (two-column on desktop) -->
    <div class="story-grid">
      <!-- Left: story text -->
      <div>
        <p
          style="
            font-family: var(--font-body);
            font-size: var(--text-base);
            color: var(--color-text-muted);
            line-height: var(--leading-relaxed);
            margin: 0 0 var(--space-6);
          "
        >
          A GMStudio nasceu da vontade de criar coisas que impressionam — e de levar isso para empreendedores que merecem uma presença digital à altura do que constroem.
        </p>
        <p
          style="
            font-family: var(--font-body);
            font-size: var(--text-base);
            color: var(--color-text-muted);
            line-height: var(--leading-relaxed);
            margin: 0;
          "
        >
          Unimos design fora do comum com tecnologia moderna. Você fala direto com quem faz, sem intermediários — e o resultado é um site que representa de verdade o seu negócio.
        </p>
      </div>

      <!-- Right: stats -->
      <StatsCounter stats={statsData} client:visible />
    </div>

    <!-- Values block -->
    <div style="margin-top: var(--space-12);">
      <h3 class="section-heading">Nossos valores</h3>
      <div class="values-grid">
        {values.map((value) => (
          <div class="value-card">
            <h3
              style="
                font-family: var(--font-heading);
                font-size: var(--text-xl);
                font-weight: 700;
                color: var(--color-text);
                margin: 0 0 var(--space-2);
              "
            >
              {value.name}
            </h3>
            <p
              style="
                font-family: var(--font-body);
                font-size: var(--text-base);
                color: var(--color-text-muted);
                margin: 0;
                line-height: var(--leading-normal);
              "
            >
              {value.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Team cards (only if team data exists) -->
    {team.length > 0 && (
      <div style="margin-top: var(--space-12);">
        <h3 class="section-heading">Nossa equipe</h3>
        <div class="team-grid">
          {team.map((member) => (
            <div class="glass-card" style="padding: var(--space-8); text-align: center;">
              {member.data.photo ? (
                <img
                  src={member.data.photo}
                  alt={member.data.name}
                  loading="lazy"
                  decoding="async"
                  width="80"
                  height="80"
                  style="
                    width: 80px;
                    height: 80px;
                    border-radius: 50%;
                    object-fit: cover;
                    margin: 0 auto;
                    display: block;
                  "
                />
              ) : (
                <div
                  aria-hidden="true"
                  style="
                    width: 80px;
                    height: 80px;
                    border-radius: 50%;
                    background: var(--color-accent-surface);
                    color: var(--color-accent);
                    font-family: var(--font-heading);
                    font-weight: 700;
                    font-size: var(--text-2xl);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin: 0 auto;
                  "
                >
                  {member.data.name.charAt(0)}
                </div>
              )}
              <h3
                style="
                  font-family: var(--font-heading);
                  font-size: var(--text-xl);
                  font-weight: 700;
                  color: var(--color-text);
                  margin: var(--space-4) 0 0;
                "
              >
                {member.data.name}
              </h3>
              <p
                style="
                  font-family: var(--font-body);
                  font-size: var(--text-sm);
                  color: var(--color-text-muted);
                  margin: var(--space-1) 0 0;
                "
              >
                {member.data.role}
              </p>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  section#sobre {
    padding: var(--space-16) var(--space-6);
  }

  @media (min-width: 1024px) {
    section#sobre {
      padding: var(--space-24) var(--space-4);
    }
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-12);
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .section-heading {
      font-size: var(--text-5xl);
    }
  }

  .story-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 1024px) {
    .story-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: center;
    }
  }

  .value-card {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .team-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    justify-content: center;
  }

  .team-grid > * {
    width: 220px;
    flex-shrink: 0;
  }
</style>
