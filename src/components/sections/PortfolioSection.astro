---
import { getCollection } from 'astro:content';
import HorizontalPortfolio from '../blocks/HorizontalPortfolio.tsx';

const rawProjects = (await getCollection('projects'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured));

// Serialize to plain objects — raw content entries are not serializable as island props
const projects = rawProjects.map((p) => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  thumbnail: p.data.thumbnail,
  liveUrl: p.data.liveUrl,
  featured: p.data.featured ?? false,
}))
---

<section id="portfolio" style="padding: var(--space-24) 0; background: var(--color-surface); min-height: 100vh; display: flex; align-items: center;">
  {projects.length === 0 ? (
    <div style="max-width: 80rem; margin: 0 auto; width: 100%;">
      <span class="eyebrow-label">Portfólio</span>
      <h2 class="text-4xl lg:text-5xl font-bold" style="font-family: var(--font-heading); line-height: var(--leading-snug); letter-spacing: var(--tracking-tight); text-align: center; margin-bottom: var(--space-12); margin-top: 0; color: var(--color-text);">
        Nossos projetos
      </h2>
      <p style="text-align: center; color: var(--color-text-muted); font-family: var(--font-body);">
        Em breve novos projetos aqui.
      </p>
    </div>
  ) : (
    <HorizontalPortfolio projects={projects} client:load />
  )}
</section>

<style is:global>
  /* Grid layout — defined here so it applies to the island's className="portfolio-grid" */
  .portfolio-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
    /* min-height prevents CLS when cards filter out */
    min-height: 300px;
  }

  @media (min-width: 640px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .portfolio-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 639px) {
    section {
      padding: var(--space-16) var(--space-6) !important;
    }
  }

  /* Keep .project-card hover rule for non-JS / CSS fallback */
  .project-card {
    border-radius: var(--radius-lg);
  }
</style>
