---
import MagicRings from "../ui/MagicRings.jsx";
import HeroContent from "../blocks/HeroContent.tsx";
---

<section id="hero" class="hero-section">
  <!-- MagicRings WebGL background — React island -->
  <div class="hero-ripple-bg">
    <MagicRings
      color="#6366F1"
      colorTwo="#a855f7"
      speed={0.8}
      ringCount={8}
      attenuation={10}
      lineThickness={2.5}
      opacity={0.8}
      followMouse={true}
      mouseInfluence={0.3}
      clickBurst={true}
      client:load
    />
  </div>

  <!-- Hero content -->
  <div class="hero-content-wrapper">
    <HeroContent client:load />

    <noscript>
      <h1 class="noscript-title">Seu concorrente já vende online. E você?</h1>
    </noscript>
  </div>

</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 80px;
    padding-bottom: 96px;
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero-ripple-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  /* Allow mouse events to pass to RippleGrid for the interactive effect */
  .hero-section:hover .hero-ripple-bg {
    pointer-events: auto;
  }

  .hero-content-wrapper {
    position: relative;
    z-index: 1;
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .noscript-title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
    text-align: center;
  }

  .noscript-desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: var(--space-6) auto 0;
    text-align: center;
    line-height: var(--leading-normal);
  }
</style>
