---
import ContactForm from './ContactForm.tsx';

const whatsappPhone = '5543996142514';
const whatsappMessage = encodeURIComponent('Olá, vim pelo site da GMStudio');
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${whatsappMessage}`;
---

<section id="contato" class="section-animate section-with-eyebrow" style="padding: var(--space-24) var(--space-6);">
  <div style="max-width: 80rem; margin: 0 auto;">
    <span class="eyebrow-label">Contato</span>
    <h2 class="text-4xl lg:text-5xl font-bold" style="font-family: var(--font-heading); line-height: var(--leading-snug); letter-spacing: var(--tracking-tight); text-align: center; margin-bottom: var(--space-12); margin-top: 0; color: var(--color-text);">
      Vamos conversar?
    </h2>

    <div class="contact-grid">
      <!-- Left column: WhatsApp block -->
      <div class="glass-card" style="padding: var(--space-8);">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>

        <h3 style="font-family: var(--font-heading); font-size: var(--text-2xl); font-weight: 700; color: var(--color-text); margin-top: var(--space-4); margin-bottom: 0;">
          Fale direto pelo WhatsApp
        </h3>

        <p style="font-family: var(--font-body); color: var(--color-text-muted); margin-top: var(--space-3); margin-bottom: 0;">
          Resposta rápida, sem formulários. Clique abaixo e nos mande uma mensagem.
        </p>

        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-cta"
          style="background: #25D366; border-radius: var(--radius-full); min-height: 44px; padding: 0 var(--space-8); font-family: var(--font-heading); font-weight: 700; font-size: var(--text-base); color: #fff; display: inline-flex; align-items: center; gap: var(--space-2); text-decoration: none; margin-top: var(--space-6);"
        >
          Falar no WhatsApp
        </a>

        <div style="margin-top: var(--space-4);">
          {/* TODO: replace with real email */}
          <a
            href="mailto:contato@gmstudio.com.br"
            style="color: var(--color-accent); font-family: var(--font-body); font-size: var(--text-base); text-decoration: none;"
          >
            contato@gmstudio.com.br
          </a>
        </div>

        <div style="display: flex; gap: var(--space-2); margin-top: var(--space-4);">
          {/* TODO: replace with real Instagram URL */}
          <a
            href="https://instagram.com/gmstudio"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon-link"
            aria-label="Instagram da GMStudio"
            style="min-height: 44px; min-width: 44px; display: inline-flex; align-items: center; justify-content: center; color: var(--color-text-muted);"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          {/* TODO: replace with real LinkedIn URL */}
          <a
            href="https://linkedin.com/company/gmstudio"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon-link"
            aria-label="LinkedIn da GMStudio"
            style="min-height: 44px; min-width: 44px; display: inline-flex; align-items: center; justify-content: center; color: var(--color-text-muted);"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right column: Contact form -->
      <div>
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }
  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    section {
      padding: var(--space-16) var(--space-6) !important;
    }
  }
  .whatsapp-cta:hover {
    background: #128C7E !important;
  }
  .social-icon-link:hover {
    color: var(--color-text) !important;
  }
  /* is:global so it applies to ContactForm React island DOM */
  :global(.contact-input:focus) {
    border-color: var(--color-accent);
    outline: none;
  }
  :global(.contact-input:focus-visible) {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
