---
import { getCollection } from 'astro:content';
import ServicesAnimations from './ServicesAnimations.tsx';

const services = await getCollection('services');
const serviceData = services.map(s => ({
  id: s.id,
  title: s.data.title,
  description: s.data.description,
  icon: s.data.icon,
}));

const processSteps = [
  { number: 1, title: 'Briefing', description: 'Entendemos seu negócio, público e objetivos para alinhar expectativas antes de começar.' },
  { number: 2, title: 'Desenvolvimento', description: 'Criamos o layout e desenvolvemos cada detalhe do site com atenção ao design e à performance.' },
  { number: 3, title: 'Entrega', description: 'Publicamos o site, entregamos os acessos e garantimos que tudo está funcionando perfeitamente.' },
];
---

<section id="servicos" class="section-with-eyebrow">
  <div style="max-width: 80rem; margin: 0 auto;">
    <span class="eyebrow-label">Serviços</span>
    <h2 class="section-heading">O que fazemos</h2>

    <ServicesAnimations
      services={serviceData}
      processSteps={processSteps}
      client:visible
    />

    <div class="services-cta">
      <p class="services-cta-text">Pronto para começar?</p>
      <a href="#contato" class="btn-primary">Solicitar orçamento</a>
    </div>
  </div>
</section>

<style>
  section#servicos {
    padding: var(--space-16) var(--space-6);
  }

  @media (min-width: 1024px) {
    section#servicos {
      padding: var(--space-24) var(--space-4);
    }
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-12);
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .section-heading {
      font-size: var(--text-5xl);
    }
  }
</style>

<style is:global>
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .process-steps {
      flex-direction: row;
      gap: 0;
      align-items: flex-start;
    }

    .process-step {
      flex: 1;
      position: relative;
      padding-right: var(--space-8);
    }

    .process-step:not(:last-child)::after {
      content: '';
      display: block;
      position: absolute;
      right: 0;
      top: 16px;
      width: var(--space-8);
      height: 1px;
      border-top: 1px dashed var(--color-border);
    }
  }

  .services-cta {
    text-align: center;
    margin-top: var(--space-16);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .services-cta-text {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    box-shadow: var(--shadow-glow);
  }
</style>
