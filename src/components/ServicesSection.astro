---
import MagicBento from "./MagicBento.tsx";

const bentoCards = [
  {
    color: "var(--color-surface)",
    label: "Menu",
    title: "Cardápio Digital",
    description: "Menu interativo para restaurantes, bares e delivery.",
  },
  {
    color: "var(--color-surface)",
    label: "Web",
    title: "Site Institucional",
    description:
      "Presença digital profissional para empresas e empreendedores.",
  },
  {
    color: "var(--color-surface)",
    label: "Conversão",
    title: "Landing Page",
    description: "Página de alta performance para campanhas e lançamentos.",
  },
  {
    color: "var(--color-surface)",
    label: "E-commerce",
    title: "Loja Online",
    description:
      "E-commerce completo com catálogo, carrinho e checkout integrado.",
  },
  {
    color: "var(--color-surface)",
    label: "SEO",
    title: "Performance & SEO",
    description: "Apareça no Google e carregue em menos de 1 segundo.",
  },
  {
    color: "var(--color-surface)",
    label: "Suporte",
    title: "Suporte Contínuo",
    description: "Atendimento dedicado e manutenção pós-entrega.",
  },
];
---

<section id="servicos" class="services-section">
  <div class="services-inner">
    <span class="eyebrow-label">O que criamos</span>
    <h2 class="section-heading">Feito <em class="accent-italic">sob medida</em><br />para o seu negócio</h2>

    <MagicBento
      cardData={bentoCards}
      glowColor="var(--color-accent-rgb)"
      enableStars={true}
      enableSpotlight={true}
      enableBorderGlow={true}
      enableTilt={true}
      clickEffect={true}
      enableMagnetism={true}
      client:visible
    />
  </div>
</section>

<style>
  .services-section {
    padding: var(--space-16) var(--space-6);
  }

  @media (min-width: 1024px) {
    .services-section {
      padding: var(--space-24) var(--space-4);
    }
  }

  .services-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-10);
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .section-heading {
      font-size: var(--text-5xl);
    }
  }

  .bento-wrapper {
    display: flex;
    justify-content: center;
  }

  .services-cta {
    text-align: center;
    margin-top: var(--space-14);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .services-cta-text {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-8);
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    box-shadow: var(--shadow-glow);
  }
</style>

<style is:global>
  /* MagicBento overrides to match site theme */
  .card-grid {
    max-width: 72rem;
  }

  .magic-bento-card {
    border-color: var(--color-border);
    font-family: var(--font-body);
  }

  .magic-bento-card__label {
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.85;
  }

  .magic-bento-card__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-text);
    margin: 0 0 0.35em;
  }

  .magic-bento-card__description {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }
</style>
