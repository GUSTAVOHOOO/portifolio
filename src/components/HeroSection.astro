---
import HeroContent from './HeroContent.tsx';
---

<section
  id="hero"
  class="hero-bg-animated"
  style="
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 80px;
    padding-bottom: 96px;
    position: relative;
  "
>
  <div style="max-width: 48rem; margin: 0 auto; padding: 0 1rem;">
    <!-- React island: animated headline + CTAs -->
    <HeroContent client:load />

    <!-- No-JS fallback: always rendered in static HTML, hidden when JS is present -->
    <noscript>
      <h1 style="font-family: var(--font-heading); font-size: var(--text-5xl); font-weight: 700; line-height: var(--leading-tight); letter-spacing: var(--tracking-tight); color: var(--color-text); margin: 0; text-align: center;">
        Presença digital que converte
      </h1>
      <p style="font-family: var(--font-body); font-size: var(--text-base); color: var(--color-text-muted); max-width: 560px; margin: var(--space-6) auto 0; text-align: center; line-height: var(--leading-normal);">
        Criamos sites e lojas online que geram resultados reais para o seu negócio.
      </p>
    </noscript>
  </div>
</section>

<style>
  @keyframes hero-mesh-shift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .hero-bg-animated {
    background:
      radial-gradient(ellipse 120% 80% at 60% -20%, rgba(99, 102, 241, 0.70), transparent 60%),
      radial-gradient(ellipse 80% 60% at 10% 80%, rgba(139, 92, 246, 0.55), transparent 55%),
      radial-gradient(ellipse 60% 40% at 90% 60%, rgba(6, 182, 212, 0.45), transparent 50%),
      var(--color-bg);
    background-size: 300% 300%;
    animation: hero-mesh-shift 12s ease infinite;
  }
</style>
