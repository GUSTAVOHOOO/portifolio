---
import HeroContent from './HeroContent.tsx';
import AuroraBackground from './AuroraBackground.tsx';
---

<section
  id="hero"
  class="hero-bg-animated"
  style="
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 80px;
    padding-bottom: 96px;
    position: relative;
  "
>
  <!-- Aurora animated background — React island, gates animation on client mount -->
  <AuroraBackground client:load />

  <div style="max-width: 48rem; margin: 0 auto; padding: 0 1rem; position: relative; z-index: 1;">
    <!-- React island: animated headline + CTAs -->
    <HeroContent client:load />

    <!-- No-JS fallback: always rendered in static HTML, hidden when JS is present -->
    <noscript>
      <h1 style="font-family: var(--font-heading); font-size: var(--text-5xl); font-weight: 700; line-height: var(--leading-tight); letter-spacing: var(--tracking-tight); color: var(--color-text); margin: 0; text-align: center;">
        Presença digital que converte
      </h1>
      <p style="font-family: var(--font-body); font-size: var(--text-base); color: var(--color-text-muted); max-width: 560px; margin: var(--space-6) auto 0; text-align: center; line-height: var(--leading-normal);">
        Criamos sites e lojas online que geram resultados reais para o seu negócio.
      </p>
    </noscript>
  </div>
</section>

<style>
  /* Aurora component provides the animated blobs — keep section background simple */
  .hero-bg-animated {
    background: var(--color-bg);
  }
</style>
