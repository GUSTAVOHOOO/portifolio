---
import PillNav from "./PillNav.tsx";
import logoUrl from "../assets/logo/gmstudio-icon-mono.svg?url";

const navLinks = [
  { href: "#servicos", label: "Serviços" },
  { href: "#portfolio", label: "Portfólio" },
  { href: "#sobre", label: "Sobre" },
  { href: "#contato", label: "Contato" },
] satisfies { href: string; label: string }[];
---

<PillNav
  logo={logoUrl}
  logoAlt="GMStudio"
  items={navLinks}
  ctaHref="#contato"
  baseColor="var(--color-text)"
  pillColor="var(--color-surface)"
  pillTextColor="var(--color-text)"
  hoveredPillTextColor="var(--color-bg)"
  client:load
/>

